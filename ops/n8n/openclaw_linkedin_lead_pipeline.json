      "name": "Leadleri Normalize Et",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const payload = items[0].json.body ?? items[0].json;\nconst leads = Array.isArray(payload) ? payload : (payload.leads ?? [payload]);\n\nfunction cleanString(value) {\n  return typeof value === 'string' ? value.trim() : '';\n}\n\nfunction pickLeadUrl(item) {\n  const explicitLinkedin = cleanString(item['LinkedIn URL'] || item.linkedin_url);\n  const fallbackUrl = cleanString(item.URL || item.website || '');\n  if (explicitLinkedin) return explicitLinkedin;\n  return fallbackUrl.includes('linkedin.com/company/') ? fallbackUrl : '';\n}\n\nreturn leads.map((item, index) => {\n  const linkedinUrl = pickLeadUrl(item);\n  const website = cleanString(item.Website || item.website || '');\n  const salesScript = cleanString(item['Sales Script'] || item.sales_script || item.message || item.gonderilecek_mesaj || '');\n\n  return {\n    json: {\n      source_index: index,\n      sirket: cleanString(item.company_name || item.sirket || item.Sirket || ''),\n      skor: Number(item.score || item.Skor || 0),\n      website,\n      linkedin_url: linkedinUrl,\n      lead_url: linkedinUrl || website,\n      mesaj: salesScript,\n      kaynak: cleanString(item.kaynak || item.Kaynak || ''),\n      detayli_analiz: cleanString(item.analysis || item.detayli_analiz || ''),\n      lead_type: linkedinUrl ? 'linkedin_ready' : 'web_only'\n    }\n  };\n});"
      }
    },
    {
      "id": "n3",
